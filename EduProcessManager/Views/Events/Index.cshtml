@model IEnumerable<EduEvent>

@{
    ViewData["Title"] = "Заходи";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0">Освітні заходи</h2>

    @if (User.IsInRole("Teacher") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
    {
        <a class="btn edu-btn px-4" asp-action="Create">Створити захід</a>
    }
</div>

@if (!Model.Any())
{
    <div class="soft-card p-4 text-center">
        <h5>Наразі немає доступних заходів</h5>
        <p class="text-muted mb-0">Спробуйте пізніше або створіть новий.</p>
    </div>
}
else
{
    @foreach (var e in Model)
    {
        var now = DateTime.Now;
        var duration = e.EndAt > e.StartAt ? e.EndAt - e.StartAt : TimeSpan.Zero;

        string statusText;
        string statusClass;

        if (now >= e.StartAt && now <= e.EndAt)
        {
            statusText = "В процесі";
            statusClass = "bg-primary";
        }
        else if (now > e.EndAt)
        {
            statusText = "Прострочений";
            statusClass = "bg-danger";
        }
        else if (e.RegistrationAvailableFrom != null && e.RegistrationAvailableFrom > now)
        {
            statusText = "Очікується";
            statusClass = "bg-warning text-dark";
        }
        else if (e.RegistrationAvailableUntil != null && e.RegistrationAvailableUntil < now)
        {
            statusText = "Прострочений";
            statusClass = "bg-danger";
        }
        else if (!e.IsRegistrationOpen)
        {
            statusText = "Реєстрація закрита";
            statusClass = "bg-secondary";
        }
        else
        {
            statusText = "Активний до реєстрації";
            statusClass = "bg-success";
        }

        <div class="soft-card p-4 mb-3 d-flex align-items-center gap-3">
            <div class="event-date text-center">
                <div class="fw-bold fs-4">@e.StartAt.Day</div>
                <div class="small text-uppercase">@e.StartAt.ToString("MMM")</div>
            </div>

            <div class="flex-grow-1">
                <div class="mb-2">
                    <span class="badge @statusClass">@statusText</span>
                </div>

                <h4 class="mb-1">@e.Title</h4>

                <p class="text-muted mb-2">@e.Description</p>

                <div class="small text-muted">
                    @e.Location · @e.StartAt.ToString("dd.MM.yyyy HH:mm") – @e.EndAt.ToString("dd.MM.yyyy HH:mm") ·
                    <strong>вільно місць:</strong> @e.FreePlaces
                </div>

                @if (duration.TotalMinutes > 0)
                {
                    <div class="small text-muted mt-1">
                        Тривалість:
                        @if (duration.Days > 0)
                        {
                            <span>@duration.Days дн.</span>
                        }
                        @if (duration.Hours > 0)
                        {
                            <span>@duration.Hours год.</span>
                        }
                        @if (duration.Minutes > 0)
                        {
                            <span>@duration.Minutes хв.</span>
                        }
                    </div>
                }

                @if (e.RegistrationAvailableFrom != null || e.RegistrationAvailableUntil != null)
                {
                    <div class="small text-muted mt-1">
                        @if (e.RegistrationAvailableFrom != null)
                        {
                            <span>Реєстрація з: @e.RegistrationAvailableFrom.Value.ToString("dd.MM.yyyy HH:mm")</span>
                        }

                        @if (e.RegistrationAvailableUntil != null)
                        {
                            <span class="ms-2">Реєстрація до: @e.RegistrationAvailableUntil.Value.ToString("dd.MM.yyyy HH:mm")</span>
                        }
                    </div>
                }
            </div>

            <div class="d-flex flex-column gap-2">
                <a class="btn accent-btn" asp-action="Details" asp-route-id="@e.Id">Деталі</a>

                @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
                {
                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@e.Id">Редагувати</a>
                }
            </div>
        </div>
    }
}