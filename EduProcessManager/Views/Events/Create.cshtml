@model EduEvent

@{
    ViewData["Title"] = "Створення заходу";
}

<div class="soft-card p-4">
    <h2 class="section-title mb-4">Новий захід</h2>

    <form method="post">
        <div class="mb-3">
            <label class="form-label">Назва</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Опис</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Місце</label>
            <input asp-for="Location" class="form-control" />
            <span asp-validation-for="Location" class="text-danger"></span>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label">Початок заходу</label>
                <input asp-for="StartAt"
                       type="datetime-local"
                       class="form-control"
                       value="@Model.StartAt.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="StartAt" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Кінець заходу</label>
                <input asp-for="EndAt"
                       type="datetime-local"
                       class="form-control"
                       value="@Model.EndAt.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="EndAt" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label">Реєстрація доступна з</label>
                <input asp-for="RegistrationAvailableFrom"
                       type="datetime-local"
                       class="form-control"
                       value="@Model.RegistrationAvailableFrom?.ToString("yyyy-MM-ddTHH:mm")" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Реєстрація доступна до</label>
                <input asp-for="RegistrationAvailableUntil"
                       type="datetime-local"
                       class="form-control"
                       value="@Model.RegistrationAvailableUntil?.ToString("yyyy-MM-ddTHH:mm")" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Кількість місць</label>
            <input asp-for="Capacity" type="number" min="1" class="form-control" />
            <span asp-validation-for="Capacity" class="text-danger"></span>
        </div>

        <div class="form-check form-switch mb-4">
            <input asp-for="IsRegistrationOpen" class="form-check-input" />
            <label class="form-check-label">Реєстрація відкрита</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn edu-btn px-4">Зберегти</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
        </div>
    </form>
</div>