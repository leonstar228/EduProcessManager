@model BellSchedule

@{
    ViewData["Title"] = "Додати дзвінок";
}

<div class="soft-card p-4">
    <h2 class="section-title mb-4">Додати дзвінок</h2>

    <form asp-controller="BellSchedule" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label">Номер заняття</label>
            <input asp-for="LessonNumber" type="number" min="1" class="form-control" />
            <span asp-validation-for="LessonNumber" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Назва</label>
            <input asp-for="Name" class="form-control" placeholder="Наприклад: 1 пара" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label class="form-label">Початок</label>
                <input asp-for="StartTime" type="time" class="form-control" />
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Кінець</label>
                <input asp-for="EndTime" type="time" class="form-control" />
                <span asp-validation-for="EndTime" class="text-danger"></span>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn edu-btn px-4">
                Зберегти
            </button>

            <a asp-controller="BellSchedule" asp-action="Index" class="btn btn-outline-secondary">
                Назад
            </a>
        </div>
    </form>
</div>