@model Test

@{
    ViewData["Title"] = "Деталі тесту";
}

<div class="soft-card p-4 mb-4">
    <div class="badge badge-soft mb-2">@Model.Subject?.Name</div>

    <h2 class="section-title">@Model.Title</h2>

    <p class="text-muted">@Model.Description</p>

    @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
    {
        <div class="d-flex gap-2 mt-3 flex-wrap">
            <a asp-controller="Tests"
               asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-outline-primary">
                Редагувати тест
            </a>

            <a asp-controller="TestQuestions"
               asp-action="Questions"
               asp-route-testId="@Model.Id"
               class="btn edu-btn">
                Редагувати питання
            </a>

            <form asp-controller="Tests"
                  asp-action="Delete"
                  asp-route-id="@Model.Id"
                  method="post"
                  onsubmit="return confirm('Видалити цей тест?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    Видалити тест
                </button>
            </form>
        </div>
    }

    <div class="row g-3 mt-3">
        <div class="col-md-4">
            <div class="soft-card p-3">
                <div class="text-muted">Пройшло учнів</div>
                <h3>@ViewBag.StudentsCount</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="soft-card p-3">
                <div class="text-muted">Середній бал</div>
                <h3>@ViewBag.AverageScore</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="soft-card p-3">
                <div class="text-muted">Середній відсоток</div>
                <h3>@ViewBag.AveragePercent%</h3>
            </div>
        </div>
    </div>
</div>

<div class="soft-card p-4">
    <h3 class="section-title mb-3">Результати учнів</h3>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Учень</th>
                    <th>Бал</th>
                    <th>Відсоток</th>
                    <th>Дата проходження</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Attempts.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            Цей тест ще ніхто не проходив
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var attempt in Model.Attempts.OrderByDescending(a => a.FinishedAt))
                    {
                        var percent = attempt.MaxScore == 0
                        ? 0
                        : Math.Round(attempt.Score * 100.0 / attempt.MaxScore, 1);

                        <tr>
                            <td>@attempt.Student?.FullName</td>
                            <td>@attempt.Score / @attempt.MaxScore</td>
                            <td>@percent%</td>
                            <td>@attempt.FinishedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <a asp-controller="Tests"
           asp-action="Index"
           class="btn btn-outline-secondary">
            Назад до тестів
        </a>
    </div>
</div>