@model EduProcessManager.Controllers.UserFormViewModel
@{ ViewData["Title"] = "Створення користувача"; var roles = ViewBag.AllowedRoles as string[] ?? Array.Empty<string>(); }

<div class="soft-card p-4">
    <h2 class="section-title">Новий користувач</h2>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <label class="form-label">ПІБ</label>
        <input asp-for="FullName" class="form-control mb-3" />
        <label class="form-label">Email</label>
        <input asp-for="Email" class="form-control mb-3" />
        <label class="form-label">Пароль</label>
        <input asp-for="Password" type="password" class="form-control mb-3" />
        <label class="form-label">Роль</label>
        <select asp-for="Role" class="form-select mb-3">
            <option value="">Оберіть роль</option>
            @foreach (var role in roles)
            {
                <option value="@role">@role</option>
            }
        </select>
        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" />
            <label class="form-check-label">Активний обліковий запис</label>
        </div>
        <button class="btn edu-btn">Створити</button>
        <a class="btn btn-outline-secondary" asp-action="Users">Назад</a>
    </form>
</div>
