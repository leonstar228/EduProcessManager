@model TestAttempt

@{
    ViewData["Title"] = "Результат тесту";
    var percent = Model.MaxScore == 0 ? 0 : Math.Round(Model.Score * 100.0 / Model.MaxScore, 1);
}

<div class="soft-card p-4 text-center">
    <h2 class="section-title mb-3">Результат тесту</h2>

    <h4 class="mb-2">@Model.Test?.Title</h4>

    <div class="display-5 fw-bold mb-2">
        @Model.Score / @Model.MaxScore
    </div>

    <div class="text-muted mb-3">
        @percent%
    </div>

    <div class="progress mb-4" style="height: 14px;">
        <div class="progress-bar"
             role="progressbar"
             style="width: @percent%">
        </div>
    </div>

    <div class="text-muted mb-4">
        Початок: @Model.StartedAt.ToString("dd.MM.yyyy HH:mm")<br />
        Завершення: @Model.FinishedAt.ToString("dd.MM.yyyy HH:mm")
    </div>

    <div class="d-flex justify-content-center gap-2">
        <a asp-controller="Tests" asp-action="Index" class="btn btn-outline-secondary">
            До тестів
        </a>

        <a asp-controller="TestPassing" asp-action="MyResults" class="btn edu-btn">
            Мої результати
        </a>
    </div>
</div>