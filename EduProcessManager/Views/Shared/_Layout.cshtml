<!doctype html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - EduFlow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg app-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span>Edu</span>Flow
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Панель</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Tests" asp-action="Index">Тести</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Events" asp-action="Index">Заходи</a>
                    </li>

                    @if (User.IsInRole("Student"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TestPassing" asp-action="MyResults">
                                Мої результати
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TestResults" asp-action="Results">
                                Результати
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Users">
                                Користувачі
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown">
                                Розклад
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Schedule"
                                       asp-action="Index">
                                        Розклад занять
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="BellSchedule"
                                       asp-action="Index">
                                        Дзвінки
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Schedule"
                               asp-action="Index">
                                Розклад
                            </a>
                        </li>
                    }
                </ul>

                <div class="d-flex gap-2 align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="user-pill">@User.Identity.Name</span>

                        <a class="btn btn-sm btn-outline-light" asp-controller="Account" asp-action="Logout">
                            Вийти
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Info"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
                @TempData["Info"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", false)
</body>
</html>