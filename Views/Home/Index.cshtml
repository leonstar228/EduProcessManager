@{ ViewData["Title"] = "Панель"; }
<div class="hero mb-4">
    <div class="row align-items-center">
        <div class="col-lg-8"><div class="badge badge-soft mb-3">Управління освітнім процесом</div><h1>Єдиний простір для тестів, заходів і результатів</h1><p class="lead text-muted">Система підтримує ролі суперадміна, адміністратора, викладача та студента.</p></div>
        <div class="col-lg-4 text-lg-end"><a class="btn edu-btn btn-lg" asp-controller="Tests" asp-action="Index">Перейти до тестів</a></div>
    </div>
</div>
<div class="row g-3">
    <div class="col-md-3"><div class="soft-card stat"><div class="num">@ViewBag.Tests</div><div class="label">тестів</div></div></div>
    <div class="col-md-3"><div class="soft-card stat"><div class="num">@ViewBag.Events</div><div class="label">заходів</div></div></div>
    <div class="col-md-3"><div class="soft-card stat"><div class="num">@ViewBag.Attempts</div><div class="label">спроб</div></div></div>
    <div class="col-md-3"><div class="soft-card stat"><div class="num">@ViewBag.Registrations</div><div class="label">реєстрацій</div></div></div>
</div>
<div class="soft-card p-4 mt-4"><h3 class="section-title">Рекомендований сценарій демонстрації</h3><p class="text-muted mb-0">Адміністратор перевіряє користувачів, викладач створює тест або захід, студент проходить тестування та реєструється на подію, після чого викладач переглядає результати.</p></div>
