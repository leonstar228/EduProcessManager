@model EduEvent
@{ ViewData["Title"] = "Створення заходу"; }
<div class="soft-card p-4"><h2 class="section-title">Новий захід</h2><form method="post"><label class="form-label">Назва</label><input asp-for="Title" class="form-control mb-3"/><label class="form-label">Опис</label><textarea asp-for="Description" class="form-control mb-3"></textarea><label class="form-label">Місце</label><input asp-for="Location" class="form-control mb-3"/><label class="form-label">Дата і час</label><input asp-for="StartAt" type="datetime-local" class="form-control mb-3"/><label class="form-label">Кількість місць</label><input asp-for="Capacity" class="form-control mb-3"/><div class="form-check mb-3"><input asp-for="IsRegistrationOpen" class="form-check-input"/><label class="form-check-label">Реєстрація відкрита</label></div><button class="btn edu-btn">Зберегти</button></form></div>
