@model EduEvent
@{ ViewData["Title"] = "Деталі заходу"; }
<div class="soft-card p-4 mb-3"><h2>@Model.Title</h2><p class="text-muted">@Model.Description</p><p><strong>Місце:</strong> @Model.Location</p><p><strong>Дата:</strong> @Model.StartAt.ToString("dd.MM.yyyy HH:mm")</p><p><strong>Вільно місць:</strong> @Model.FreePlaces</p>@if(User.IsInRole("Student")){<form asp-action="Register" method="post"><input type="hidden" name="id" value="@Model.Id"/><button class="btn edu-btn">Зареєструватися</button></form>}</div>
@if(User.IsInRole("Teacher")||User.IsInRole("Admin")||User.IsInRole("SuperAdmin")){<div class="soft-card p-4"><h4>Учасники</h4><table class="table"><thead><tr><th>Студент</th><th>Статус</th><th></th></tr></thead><tbody>@foreach(var r in Model.Registrations){<tr><td>@r.Student?.FullName</td><td>@r.Status</td><td><form asp-action="Confirm" method="post"><input type="hidden" name="registrationId" value="@r.Id"/><input type="hidden" name="eventId" value="@Model.Id"/><button class="btn btn-sm btn-outline-success">Підтвердити</button></form></td></tr>}</tbody></table></div>}
