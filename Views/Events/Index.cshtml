@model IEnumerable<EduEvent>
@{ ViewData["Title"] = "Заходи"; }
<div class="d-flex justify-content-between mb-3"><h2 class="section-title">Освітні заходи</h2>@if(User.IsInRole("Teacher")||User.IsInRole("Admin")||User.IsInRole("SuperAdmin")){<a class="btn edu-btn" asp-action="Create">Створити захід</a>}</div>
@foreach(var e in Model){<div class="soft-card p-4 mb-3 d-flex gap-3 align-items-center"><div class="event-date"><strong>@e.StartAt.Day</strong><span>@e.StartAt.ToString("MMM")</span></div><div class="flex-grow-1"><h4>@e.Title</h4><p class="text-muted mb-1">@e.Description</p><span>@e.Location · @e.StartAt.ToString("HH:mm") · вільно місць: @e.FreePlaces</span></div><a class="btn accent-btn" asp-action="Details" asp-route-id="@e.Id">Деталі</a></div>}
