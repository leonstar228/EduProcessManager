@model Test
@{ ViewData["Title"] = "Створення тесту"; }
<div class="soft-card p-4"><h2 class="section-title">Новий тест</h2><form method="post"><label class="form-label">Назва</label><input asp-for="Title" class="form-control mb-3"/><label class="form-label">Опис</label><textarea asp-for="Description" class="form-control mb-3" rows="4"></textarea><label class="form-label">Ліміт часу, хв.</label><input asp-for="TimeLimitMinutes" class="form-control mb-3"/><div class="form-check mb-3"><input asp-for="IsPublished" class="form-check-input"/><label class="form-check-label">Опубліковано</label></div><button class="btn edu-btn">Зберегти</button></form></div>
