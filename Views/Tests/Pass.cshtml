@model EduProcessManager.ViewModels.TestPassViewModel
@{ ViewData["Title"] = "Проходження тесту"; }
<div class="soft-card p-4 mb-3"><h2>@Model.Title</h2><p class="text-muted">Ліміт часу: @Model.TimeLimitMinutes хвилин</p></div>
<form method="post"><input type="hidden" asp-for="TestId" />
@foreach(var q in Model.Questions){<div class="question-box"><h5>@q.Text <span class="text-muted">(@q.Points б.)</span></h5>@foreach(var a in q.AnswerOptions){<div class="form-check"><input class="form-check-input" type="@(q.AllowMultipleAnswers ? "checkbox" : "radio")" name="SelectedAnswers[@q.Id]" value="@a.Id" /><label class="form-check-label">@a.Text</label></div>}</div>}
<button class="btn edu-btn btn-lg">Завершити тест</button></form>
