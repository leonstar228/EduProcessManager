@model IEnumerable<TestAttempt>
@{ ViewData["Title"] = "Результати"; }
<div class="soft-card p-4"><h2 class="section-title">Журнал результатів</h2><table class="table"><thead><tr><th>Студент</th><th>Тест</th><th>Бал</th><th>Дата</th></tr></thead><tbody>@foreach(var a in Model){<tr><td>@a.Student?.FullName</td><td>@a.Test?.Title</td><td><span class="badge badge-soft">@a.Score / @a.MaxScore</span></td><td>@a.FinishedAt.ToString("dd.MM.yyyy HH:mm")</td></tr>}</tbody></table></div>
