@model IEnumerable<Test>
@{ ViewData["Title"] = "Тести"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h2 class="section-title">Доступні тести</h2>@if(User.IsInRole("Teacher")||User.IsInRole("Admin")||User.IsInRole("SuperAdmin")){<a class="btn edu-btn" asp-action="Create">Створити тест</a>}</div>
<div class="row g-3">
@foreach(var t in Model){<div class="col-md-6"><div class="soft-card p-4 h-100"><div class="badge badge-soft mb-2">@t.Subject?.Name</div><h4>@t.Title</h4><p class="text-muted">@t.Description</p><div class="d-flex justify-content-between align-items-center"><span>@t.TimeLimitMinutes хв.</span><a class="btn accent-btn" asp-action="Pass" asp-route-id="@t.Id">Пройти</a></div></div></div>}
</div>
