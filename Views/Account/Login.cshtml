@model EduProcessManager.ViewModels.LoginViewModel
@{ ViewData["Title"] = "Вхід"; Layout = "_Layout"; }
<div class="login-wrap">
    <div class="soft-card login-card">
        <div class="mb-4">
            <div class="badge badge-soft mb-3">Освітня платформа</div>
            <h2 class="fw-bold">Вхід до EduFlow</h2>
            <p class="text-muted">Демо-акаунти: superadmin@edu.local, admin@edu.local, teacher@edu.local, student@edu.local. Пароль: 123456</p>
        </div>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <label class="form-label">Email</label><input asp-for="Email" class="form-control mb-3" />
            <label class="form-label">Пароль</label><input asp-for="Password" class="form-control mb-4" />
            <button class="btn edu-btn w-100 py-2">Увійти</button>
        </form>
    </div>
</div>
